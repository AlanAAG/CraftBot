{
  "mcp_servers": [
    {
      "name": "github",
      "description": "GitHub API integration for repositories, issues, and PRs",
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      },
      "enabled": true
    }
  ],
  "auto_connect": true
}